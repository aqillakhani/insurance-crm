generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agency {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  logoUrl            String?  @map("logo_url")
  phone              String?
  email              String?
  timezone           String   @default("America/Chicago")
  subscriptionStatus String   @default("active") @map("subscription_status")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  territories  Territory[]
  offices      Office[]
  users        User[]
  roles        Role[]
  customers    Customer[]
  carriers     Carrier[]
  tags         Tag[]
  activityLogs ActivityLog[]

  @@map("agencies")
}

model Territory {
  id        String   @id @default(uuid())
  agencyId  String   @map("agency_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  agency    Agency     @relation(fields: [agencyId], references: [id])
  divisions Division[]
  @@map("territories")
}

model Division {
  id          String   @id @default(uuid())
  territoryId String   @map("territory_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  territory   Territory @relation(fields: [territoryId], references: [id])
  regions     Region[]
  @@map("divisions")
}

model Region {
  id         String   @id @default(uuid())
  divisionId String   @map("division_id")
  name       String
  createdAt  DateTime @default(now()) @map("created_at")
  division   Division   @relation(fields: [divisionId], references: [id])
  districts  District[]
  @@map("regions")
}

model District {
  id        String   @id @default(uuid())
  regionId  String   @map("region_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  region    Region   @relation(fields: [regionId], references: [id])
  offices   Office[]
  @@map("districts")
}

model Office {
  id         String   @id @default(uuid())
  agencyId   String   @map("agency_id")
  districtId String?  @map("district_id")
  name       String
  code       String?
  phone      String?
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  agency     Agency    @relation(fields: [agencyId], references: [id])
  district   District? @relation(fields: [districtId], references: [id])
  users      User[]
  customers  Customer[]
  payments   Payment[]
  @@map("offices")
}

model Role {
  id          String   @id @default(uuid())
  agencyId    String?  @map("agency_id")
  name        String
  description String?
  permissions String   @default("{}")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  agency      Agency?  @relation(fields: [agencyId], references: [id])
  users       User[]
  @@map("roles")
}

model User {
  id            String    @id @default(uuid())
  agencyId      String    @map("agency_id")
  officeId      String?   @map("office_id")
  email         String
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  roleId        String?   @map("role_id")
  avatarUrl     String?   @map("avatar_url")
  status        String    @default("active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  agency        Agency    @relation(fields: [agencyId], references: [id])
  office        Office?   @relation(fields: [officeId], references: [id])
  role          Role?     @relation(fields: [roleId], references: [id])

  customersAsAgent   Customer[] @relation("AgentOfRecord")
  customersEntered   Customer[] @relation("EnteredBy")
  customersKeyed     Customer[] @relation("KeyedBy")
  policiesAgent      Policy[]   @relation("PolicyAgent")
  policiesWriter     Policy[]   @relation("PolicyWriter")
  notesCreated       Note[]
  tasksAssigned      Task[]     @relation("TaskAssignee")
  tasksCreated       Task[]     @relation("TaskCreator")
  attachmentsAdded   Attachment[]
  paymentsProcessed  Payment[]
  communicationsSent Communication[]
  diaryEntries       DiaryEntry[]
  activityLogs       ActivityLog[]
  quotesAgent        Quote[]

  @@unique([agencyId, email])
  @@map("users")
}

model Customer {
  id                String   @id @default(uuid())
  agencyId          String   @map("agency_id")
  customerIdDisplay String   @map("customer_id_display")
  customerType      String   @default("Personal Lines") @map("customer_type")
  accountType       String   @default("Customer") @map("account_type")
  status            String   @default("Active")
  primarySubStatus  String?  @map("primary_sub_status")
  firstName         String   @map("first_name")
  lastName          String   @map("last_name")
  businessName      String?  @map("business_name")
  addressStreet     String?  @map("address_street")
  addressCity       String?  @map("address_city")
  addressState      String?  @map("address_state")
  addressZip        String?  @map("address_zip")
  addressValidated  Boolean  @default(false) @map("address_validated")
  mailingAddress    String?  @map("mailing_address")
  email             String?
  email2            String?
  cell              String?
  home              String?
  work              String?
  otherPhone        String?  @map("other_phone")
  language          String?  @default("English")
  preferredContact  String?  @map("preferred_contact")
  ssnEncrypted      String?  @map("ssn_encrypted")
  maritalStatus     String?  @map("marital_status")
  gender            String?
  dob               DateTime?
  dlNumber          String?  @map("dl_number")
  dlState           String?  @map("dl_state")
  dateLicensed      DateTime? @map("date_licensed")
  doNotEmail        Boolean  @default(false) @map("do_not_email")
  doNotText         Boolean  @default(false) @map("do_not_text")
  doNotCall         Boolean  @default(false) @map("do_not_call")
  doNotMail         Boolean  @default(false) @map("do_not_mail")
  doNotMarket       Boolean  @default(false) @map("do_not_market")
  doNotCaptureEmail Boolean  @default(false) @map("do_not_capture_email")
  agentOfRecordId   String?  @map("agent_of_record_id")
  enteredById       String?  @map("entered_by_id")
  keyedById         String?  @map("keyed_by_id")
  officeId          String?  @map("office_id")
  source            String?
  subSource         String?  @map("sub_source")
  dateAdded         DateTime @default(now()) @map("date_added")
  comments          String?
  customFields      String   @default("{}") @map("custom_fields")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agency        Agency   @relation(fields: [agencyId], references: [id])
  agentOfRecord User?    @relation("AgentOfRecord", fields: [agentOfRecordId], references: [id])
  enteredBy     User?    @relation("EnteredBy", fields: [enteredById], references: [id])
  keyedBy       User?    @relation("KeyedBy", fields: [keyedById], references: [id])
  office        Office?  @relation(fields: [officeId], references: [id])

  policies           Policy[]
  quotes             Quote[]
  xdates             XDate[]
  payments           Payment[]
  notes              Note[]
  tasks              Task[]
  attachments        Attachment[]
  claims             Claim[]
  communications     Communication[]
  diaryEntries       DiaryEntry[]
  financeEntries     FinanceEntry[]
  changeRequests     ChangeRequest[]
  householdPrimary   HouseholdMember[] @relation("HouseholdPrimary")
  householdRelated   HouseholdMember[] @relation("HouseholdRelated")
  customerTags       CustomerTag[]
  relationshipsFrom  CustomerRelationship[] @relation("RelFrom")
  relationshipsTo    CustomerRelationship[] @relation("RelTo")
  roleAssignments    RoleAssignment[]

  @@index([agencyId, status])
  @@index([agencyId, lastName, firstName])
  @@index([agencyId, email])
  @@index([agencyId, cell])
  @@index([agencyId, customerIdDisplay])
  @@map("customers")
}

model CustomerRelationship {
  id                String   @id @default(uuid())
  customerId        String   @map("customer_id")
  relatedCustomerId String   @map("related_customer_id")
  relationshipType  String   @map("relationship_type")
  createdAt         DateTime @default(now()) @map("created_at")
  customer          Customer @relation("RelFrom", fields: [customerId], references: [id])
  relatedCustomer   Customer @relation("RelTo", fields: [relatedCustomerId], references: [id])
  @@map("customer_relationships")
}

model CustomerTag {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  tagId      String   @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])
  @@unique([customerId, tagId])
  @@map("customer_tags")
}

model Tag {
  id           String        @id @default(uuid())
  agencyId     String        @map("agency_id")
  name         String
  slug         String
  color        String?
  category     String?
  createdAt    DateTime      @default(now()) @map("created_at")
  agency       Agency        @relation(fields: [agencyId], references: [id])
  customerTags CustomerTag[]
  @@unique([agencyId, slug])
  @@map("tags")
}

model Carrier {
  id                String   @id @default(uuid())
  agencyId          String   @map("agency_id")
  name              String
  code              String?
  logoUrl           String?  @map("logo_url")
  linesOffered      String?  @map("lines_offered")
  appointmentStatus String   @default("active") @map("appointment_status")
  portalUrl         String?  @map("portal_url")
  underwNotes       String?  @map("underwriting_notes")
  commissionRates   String   @default("{}") @map("commission_rates")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  agency            Agency       @relation(fields: [agencyId], references: [id])
  policies          Policy[]
  quotes            Quote[]
  payments          Payment[]
  attachments       Attachment[]
  claims            Claim[]
  @@map("carriers")
}

model Policy {
  id                   String    @id @default(uuid())
  agencyId             String    @map("agency_id")
  customerId           String    @map("customer_id")
  carrierId            String?   @map("carrier_id")
  status               String    @default("Active")
  type                 String?
  class                String?
  policyNumber         String?   @map("policy_number")
  version              Int       @default(1)
  dueDate              DateTime? @map("due_date")
  effectiveDate        DateTime? @map("effective_date")
  expirationCancelDate DateTime? @map("expiration_cancel_date")
  premium              Float     @default(0)
  rider                String?
  agentOfRecordId      String?   @map("agent_of_record_id")
  writingAgentId       String?   @map("writing_agent_id")
  coverageData         String    @default("{}") @map("coverage_data")
  customFields         String    @default("{}") @map("custom_fields")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  customer             Customer  @relation(fields: [customerId], references: [id])
  carrier              Carrier?  @relation(fields: [carrierId], references: [id])
  agentOfRecord        User?     @relation("PolicyAgent", fields: [agentOfRecordId], references: [id])
  writingAgent         User?     @relation("PolicyWriter", fields: [writingAgentId], references: [id])
  quotes               Quote[]
  payments             Payment[]
  notes                Note[]
  tasks                Task[]
  attachments          Attachment[]
  claims               Claim[]
  financeEntries       FinanceEntry[]
  changeRequests       ChangeRequest[]
  roleAssignments      RoleAssignment[]
  @@index([agencyId, customerId])
  @@index([agencyId, status])
  @@index([agencyId, policyNumber])
  @@index([agencyId, expirationCancelDate])
  @@map("policies")
}

model Quote {
  id              String    @id @default(uuid())
  agencyId        String    @map("agency_id")
  customerId      String    @map("customer_id")
  carrierId       String?   @map("carrier_id")
  policyId        String?   @map("policy_id")
  product         String?
  effectiveDate   DateTime? @map("effective_date")
  quoteDate       DateTime? @map("quote_date")
  class           String?
  premium         Float     @default(0)
  quotePayment    Float?    @map("quote_payment")
  monthlyFee      Float?    @map("monthly_fee")
  taxAmount       Float?    @map("tax_amount")
  pin             String?
  mga             String?
  agentOfRecordId String?   @map("agent_of_record_id")
  extendedFields  String    @default("{}") @map("extended_fields")
  bindStatus      String?   @map("bind_status")
  amount          Float?
  bondy           String?
  rider           String?
  status          String    @default("Pending")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  customer        Customer  @relation(fields: [customerId], references: [id])
  carrier         Carrier?  @relation(fields: [carrierId], references: [id])
  policy          Policy?   @relation(fields: [policyId], references: [id])
  agentOfRecord   User?     @relation(fields: [agentOfRecordId], references: [id])
  @@index([agencyId, customerId])
  @@map("quotes")
}

model XDate {
  id             String    @id @default(uuid())
  agencyId       String    @map("agency_id")
  customerId     String    @map("customer_id")
  carrier        String?
  lineOfBusiness String?   @map("line_of_business")
  expirationDate DateTime? @map("expiration_date")
  notes          String?
  status         String    @default("Active")
  createdAt      DateTime  @default(now()) @map("created_at")
  customer       Customer  @relation(fields: [customerId], references: [id])
  @@index([agencyId, customerId])
  @@map("xdates")
}

model Payment {
  id             String   @id @default(uuid())
  agencyId       String   @map("agency_id")
  customerId     String   @map("customer_id")
  policyId       String?  @map("policy_id")
  carrierId      String?  @map("carrier_id")
  officeId       String?  @map("office_id")
  receiptRef     String?  @map("receipt_ref")
  status         String   @default("Active")
  amountBilled   Float    @default(0) @map("amount_billed")
  amountTendered Float    @default(0) @map("amount_tendered")
  paymentDate    DateTime @default(now()) @map("payment_date")
  paymentMethod  String?  @map("payment_method")
  processedById  String?  @map("processed_by_id")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  customer       Customer @relation(fields: [customerId], references: [id])
  policy         Policy?  @relation(fields: [policyId], references: [id])
  carrier        Carrier? @relation(fields: [carrierId], references: [id])
  office         Office?  @relation(fields: [officeId], references: [id])
  processedBy    User?    @relation(fields: [processedById], references: [id])
  @@index([agencyId, customerId])
  @@index([agencyId, paymentDate])
  @@map("payments")
}

model Note {
  id           String   @id @default(uuid())
  agencyId     String   @map("agency_id")
  customerId   String   @map("customer_id")
  policyId     String?  @map("policy_id")
  noteType     String   @default("note") @map("note_type")
  content      String
  isSystemNote Boolean  @default(false) @map("is_system_note")
  isPinned     Boolean  @default(false) @map("is_pinned")
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  customer     Customer @relation(fields: [customerId], references: [id])
  policy       Policy?  @relation(fields: [policyId], references: [id])
  createdBy    User?    @relation(fields: [createdById], references: [id])
  @@index([agencyId, customerId])
  @@map("notes")
}

model Task {
  id              String    @id @default(uuid())
  agencyId        String    @map("agency_id")
  customerId      String?   @map("customer_id")
  policyId        String?   @map("policy_id")
  title           String
  description     String?
  type            String    @default("general")
  priority        String    @default("normal")
  status          String    @default("pending")
  dueDate         DateTime? @map("due_date")
  completedAt     DateTime? @map("completed_at")
  completionNotes String?   @map("completion_notes")
  assignedToId    String?   @map("assigned_to_id")
  createdById     String?   @map("created_by_id")
  isAutomated     Boolean   @default(false) @map("is_automated")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  customer        Customer? @relation(fields: [customerId], references: [id])
  policy          Policy?   @relation(fields: [policyId], references: [id])
  assignedTo      User?     @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy       User?     @relation("TaskCreator", fields: [createdById], references: [id])
  @@index([agencyId, assignedToId, status])
  @@index([agencyId, customerId])
  @@map("tasks")
}

model Attachment {
  id           String   @id @default(uuid())
  agencyId     String   @map("agency_id")
  customerId   String   @map("customer_id")
  policyId     String?  @map("policy_id")
  carrierId    String?  @map("carrier_id")
  fileName     String   @map("file_name")
  fileUrl      String   @map("file_url")
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type")
  documentType String?  @map("document_type")
  description  String?
  textContent  String?  @map("text_content")
  isPinned     Boolean  @default(false) @map("is_pinned")
  addedById    String?  @map("added_by_id")
  minutes      String?
  createdAt    DateTime @default(now()) @map("created_at")
  customer     Customer @relation(fields: [customerId], references: [id])
  policy       Policy?  @relation(fields: [policyId], references: [id])
  carrier      Carrier? @relation(fields: [carrierId], references: [id])
  addedBy      User?    @relation(fields: [addedById], references: [id])
  @@index([agencyId, customerId])
  @@map("attachments")
}

model Claim {
  id            String    @id @default(uuid())
  agencyId      String    @map("agency_id")
  customerId    String    @map("customer_id")
  policyId      String?   @map("policy_id")
  carrierId     String?   @map("carrier_id")
  claimNumber   String?   @map("claim_number")
  status        String    @default("Open")
  dateOfLoss    DateTime? @map("date_of_loss")
  dateReported  DateTime? @map("date_reported")
  description   String?
  amount        Float?
  adjusterName  String?   @map("adjuster_name")
  adjusterPhone String?   @map("adjuster_phone")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  customer      Customer  @relation(fields: [customerId], references: [id])
  policy        Policy?   @relation(fields: [policyId], references: [id])
  carrier       Carrier?  @relation(fields: [carrierId], references: [id])
  @@index([agencyId, customerId])
  @@map("claims")
}

model HouseholdMember {
  id                String   @id @default(uuid())
  customerId        String   @map("customer_id")
  relatedCustomerId String   @map("related_customer_id")
  relationship      String
  isPrimary         Boolean  @default(false) @map("is_primary")
  createdAt         DateTime @default(now()) @map("created_at")
  customer          Customer @relation("HouseholdPrimary", fields: [customerId], references: [id])
  relatedCustomer   Customer @relation("HouseholdRelated", fields: [relatedCustomerId], references: [id])
  @@map("household_members")
}

model DiaryEntry {
  id          String   @id @default(uuid())
  agencyId    String   @map("agency_id")
  customerId  String   @map("customer_id")
  entryDate   DateTime @default(now()) @map("entry_date")
  description String
  type        String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  customer    Customer @relation(fields: [customerId], references: [id])
  createdBy   User?    @relation(fields: [createdById], references: [id])
  @@index([agencyId, customerId])
  @@map("diary_entries")
}

model RoleAssignment {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  policyId   String?  @map("policy_id")
  userId     String   @map("user_id")
  roleType   String   @map("role_type")
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])
  policy     Policy?  @relation(fields: [policyId], references: [id])
  @@map("role_assignments")
}

model FinanceEntry {
  id          String   @id @default(uuid())
  agencyId    String   @map("agency_id")
  customerId  String   @map("customer_id")
  policyId    String?  @map("policy_id")
  type        String
  amount      Float
  date        DateTime
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  customer    Customer @relation(fields: [customerId], references: [id])
  policy      Policy?  @relation(fields: [policyId], references: [id])
  @@index([agencyId, customerId])
  @@map("finance_entries")
}

model Communication {
  id         String   @id @default(uuid())
  agencyId   String   @map("agency_id")
  customerId String   @map("customer_id")
  channel    String
  direction  String   @default("outbound")
  subject    String?
  body       String?
  sentById   String?  @map("sent_by_id")
  sentAt     DateTime @default(now()) @map("sent_at")
  status     String   @default("sent")
  metadata   String   @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id])
  sentBy     User?    @relation(fields: [sentById], references: [id])
  @@index([agencyId, customerId])
  @@map("communications")
}

model ChangeRequest {
  id            String    @id @default(uuid())
  agencyId      String    @map("agency_id")
  customerId    String    @map("customer_id")
  policyId      String?   @map("policy_id")
  requestType   String    @map("request_type")
  description   String
  status        String    @default("pending")
  requestedById String?   @map("requested_by_id")
  processedById String?   @map("processed_by_id")
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  customer      Customer  @relation(fields: [customerId], references: [id])
  policy        Policy?   @relation(fields: [policyId], references: [id])
  @@index([agencyId, customerId])
  @@map("change_requests")
}

model ActivityLog {
  id         String   @id @default(uuid())
  agencyId   String   @map("agency_id")
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  changes    String   @default("{}")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  agency     Agency   @relation(fields: [agencyId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
  @@index([agencyId, createdAt])
  @@index([agencyId, entityType, entityId])
  @@map("activity_logs")
}
